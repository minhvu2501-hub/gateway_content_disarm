# Force LF line endings for all shell scripts and config files
# (required for scripts to run correctly on Linux/Ubuntu)
* text=auto

*.sh    text eol=lf
*.py    text eol=lf
*.conf  text eol=lf
*.txt   text eol=lf
*.config text eol=lf
*.list  text eol=lf
Dockerfile* text eol=lf
treataslocal text eol=lf
